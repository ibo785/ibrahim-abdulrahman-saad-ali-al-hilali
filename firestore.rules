rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ENTITY VALIDATORS
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) 
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.role in ['user', 'admin']
        && (data.role == 'user' || isAdmin()); // Only admins can create other admins
    }

    function isValidItem(data) {
      return data.keys().hasAll(['ownerId', 'title', 'status', 'createdAt'])
        && data.ownerId == request.auth.uid
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.status in ['available', 'pending', 'reserved', 'exchanged']
        && data.createdAt == request.time;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['itemId', 'providerId', 'receiverId', 'type', 'status', 'createdAt'])
        && data.providerId is string && data.receiverId is string
        && data.type in ['donation', 'exchange', 'request']
        && data.status in ['pending', 'accepted', 'rejected', 'completed', 'cancelled']
        && data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'text', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.createdAt == request.time;
    }

    // RULES
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'phone', 'location', 'updatedAt'])
        && (incoming().updatedAt == request.time);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /items/{itemId} {
      allow get: if true;
      allow list: if (resource.data.status == 'available') || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && isValidItem(incoming()) && isValidId(itemId);
      allow update: if isSignedIn() && (
        isAdmin() || (
          isOwner(existing().ownerId) && isValidItem(incoming())
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'condition', 'status', 'imageUrls', 'updatedAt'])
          && (existing().status != 'exchanged')
        )
      );
      allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().ownerId) && existing().status == 'available');
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.providerId || request.auth.uid == resource.data.receiverId);
      allow list: if isSignedIn() && (isAdmin() || resource.data.providerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && isValidTransaction(incoming()) 
        && (incoming().receiverId == request.auth.uid) // Usually a receiver creates a request
        && exists(/databases/$(database)/documents/items/$(incoming().itemId));
      allow update: if isSignedIn() && (
        isAdmin() || (
          (request.auth.uid == existing().providerId || request.auth.uid == existing().receiverId)
          && isValidTransaction(incoming())
          && incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt'])
          && incoming().updatedAt == request.time
        )
      );
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() && isValidMessage(incoming()) && isValidId(messageId);
    }

    match /points_log/{logId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.userId);
      // POINTS SHOULD BE WRITE PROTECTED FROM CLIENT
      allow create: if isAdmin(); 
      allow update, delete: if false;
    }

    match /wishlists/{wishlistId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(wishlistId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    match /reports/{reportId} {
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.reporterId);
      allow list: if isAdmin();
      allow create: if isSignedIn() && incoming().reporterId == request.auth.uid && isValidId(reportId);
      allow update: if isAdmin();
    }
  }
}
